<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>상벌점 기준 학습</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700;900&family=Black+Han+Sans&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f0f4f8;
    --surface: #e2e8f0;
    --card: #ffffff;
    --border: #cbd5e1;
    --accent: #2563eb;
    --accent2: #ef4444;
    --gold: #d97706;
    --green: #059669;
    --text: #1e293b;
    --muted: #64748b;
    --exit: #dc2626;
    --warning: #ea580c;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* --- BACKGROUND --- */
  body::before {
    content: '';
    position: fixed;
    top: -200px; left: -200px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(37,99,235,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  body::after {
    content: '';
    position: fixed;
    bottom: -200px; right: -200px;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(239,68,68,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  /* --- SCREENS --- */
  .screen { display: none; min-height: 100vh; }
  .screen.active { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 24px; }

  /* --- HOME --- */
  .home-title {
    font-family: 'Black Han Sans', sans-serif;
    font-size: clamp(2rem, 6vw, 3.5rem);
    letter-spacing: -1px;
    background: linear-gradient(135deg, #1d4ed8, #7c3aed, #dc2626);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-align: center;
    margin-bottom: 8px;
  }
  .home-sub {
    color: var(--muted);
    font-size: 0.95rem;
    text-align: center;
    margin-bottom: 48px;
  }
  .mode-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    width: 100%;
    max-width: 640px;
  }
  .mode-card {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 20px;
    padding: 32px 24px;
    cursor: pointer;
    transition: all 0.25s;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .mode-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.25s;
  }
  .mode-card.flash::before { background: radial-gradient(circle at 50% 0%, rgba(79,142,247,0.15), transparent 70%); }
  .mode-card.quiz::before  { background: radial-gradient(circle at 50% 0%, rgba(247,95,79,0.15), transparent 70%); }
  .mode-card.ox::before    { background: radial-gradient(circle at 50% 0%, rgba(62,207,142,0.15), transparent 70%); }
  .mode-card:hover { transform: translateY(-4px); border-color: var(--accent); }
  .mode-card:hover::before { opacity: 1; }
  .mode-card.quiz:hover { border-color: var(--accent2); }
  .mode-card.ox:hover   { border-color: var(--green); }
  .mode-icon { font-size: 2.8rem; margin-bottom: 12px; }
  .mode-label { font-weight: 700; font-size: 1.1rem; margin-bottom: 6px; }
  .mode-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

  .stats-row {
    display: flex; gap: 16px; margin-top: 32px;
    flex-wrap: wrap; justify-content: center;
  }
  .stat-pill {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 50px;
    padding: 8px 20px;
    font-size: 0.85rem;
    color: var(--muted);
    box-shadow: 0 1px 4px rgba(0,0,0,0.05);
  }
  .stat-pill span { color: var(--text); font-weight: 700; }

  /* --- FLASHCARD --- */
  .fc-header {
    width: 100%; max-width: 600px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
  }
  .fc-progress-wrap { flex: 1; margin: 0 16px; }
  .fc-progress-bar {
    height: 6px; background: var(--border); border-radius: 99px; overflow: hidden;
  }
  .fc-progress-fill {
    height: 100%; background: linear-gradient(90deg, var(--accent), #a78bfa);
    border-radius: 99px; transition: width 0.4s;
  }
  .fc-counter { font-size: 0.85rem; color: var(--muted); margin-top: 6px; text-align: center; }

  .flashcard-wrap { perspective: 1200px; width: 100%; max-width: 600px; }
  .flashcard {
    width: 100%; height: 220px;
    position: relative; cursor: pointer;
    transform-style: preserve-3d;
    transition: transform 0.55s cubic-bezier(.4,0,.2,1);
  }
  .flashcard.flipped { transform: rotateY(180deg); }
  .fc-face {
    position: absolute; inset: 0;
    border-radius: 24px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 28px 32px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }
  .fc-front {
    background: var(--card);
    border: 1.5px solid var(--border);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  }
  .fc-back {
    background: linear-gradient(135deg, #eff6ff, #eef2ff);
    border: 1.5px solid var(--accent);
    transform: rotateY(180deg);
    box-shadow: 0 4px 16px rgba(37,99,235,0.12);
  }
  .fc-hint { font-size: 0.75rem; color: var(--muted); margin-bottom: 12px; letter-spacing: 1px; text-transform: uppercase; }
  .fc-content { font-size: 1.05rem; font-weight: 500; text-align: center; line-height: 1.7; }
  .fc-score {
    font-family: 'Black Han Sans', sans-serif;
    font-size: 3rem;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .fc-score-label { font-size: 0.85rem; color: var(--muted); }

  .fc-tag {
    display: inline-block;
    padding: 4px 12px; border-radius: 99px;
    font-size: 0.75rem; font-weight: 700;
    margin-bottom: 16px;
  }
  .tag-exit   { background: rgba(255,92,92,0.15); color: var(--exit); }
  .tag-high   { background: rgba(255,159,67,0.15); color: var(--warning); }
  .tag-mid    { background: rgba(245,197,66,0.15); color: var(--gold); }
  .tag-low    { background: rgba(62,207,142,0.15); color: var(--green); }
  .tag-minor  { background: rgba(79,142,247,0.15); color: var(--accent); }

  .fc-actions {
    display: flex; gap: 12px; margin-top: 20px; width: 100%; max-width: 600px;
  }
  .btn {
    flex: 1; padding: 14px;
    border: none; border-radius: 14px;
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 0.95rem; font-weight: 700;
    cursor: pointer; transition: all 0.2s;
  }
  .btn-prev { background: var(--card); color: var(--muted); border: 1.5px solid var(--border); }
  .btn-next { background: var(--accent); color: #fff; }
  .btn-home { background: var(--card); color: var(--muted); border: 1.5px solid var(--border); flex: 0 0 auto; padding: 14px 20px; }
  .btn:hover { filter: brightness(1.15); transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  /* --- QUIZ --- */
  .quiz-header {
    width: 100%; max-width: 640px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 8px;
  }
  .quiz-qnum { font-family: 'Black Han Sans', sans-serif; font-size: 1.1rem; color: var(--accent); }
  .quiz-score-disp { font-size: 0.9rem; color: var(--muted); }
  .quiz-score-disp span { color: var(--green); font-weight: 700; }

  .quiz-progress-bar { height: 4px; background: var(--border); border-radius: 99px; overflow: hidden; width: 100%; max-width: 640px; margin-bottom: 28px; }
  .quiz-progress-fill { height: 100%; background: linear-gradient(90deg, var(--accent2), var(--gold)); border-radius: 99px; transition: width 0.4s; }

  .quiz-card {
    background: var(--card);
    border: 1.5px solid var(--border);
    border-radius: 24px;
    padding: 32px 28px;
    width: 100%; max-width: 640px;
    margin-bottom: 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  }
  .quiz-q { font-size: 1.05rem; font-weight: 500; line-height: 1.8; margin-bottom: 28px; }

  .quiz-options { display: flex; flex-direction: column; gap: 12px; }
  .quiz-opt {
    padding: 14px 20px;
    border-radius: 14px;
    border: 1.5px solid var(--border);
    background: var(--bg);
    color: var(--text);
    font-family: 'Noto Sans KR', sans-serif;
    font-size: 0.95rem; font-weight: 500;
    cursor: pointer; text-align: left;
    transition: all 0.2s;
  }
  .quiz-opt:hover:not(:disabled) { border-color: var(--accent); background: rgba(79,142,247,0.08); }
  .quiz-opt.correct { border-color: var(--green); background: rgba(62,207,142,0.12); color: var(--green); }
  .quiz-opt.wrong   { border-color: var(--exit);  background: rgba(255,92,92,0.10);  color: var(--exit); }
  .quiz-opt:disabled { cursor: default; }

  .quiz-feedback {
    display: none; margin-top: 16px;
    padding: 14px 18px; border-radius: 12px;
    font-size: 0.9rem; font-weight: 500; line-height: 1.6;
  }
  .quiz-feedback.show { display: block; }
  .quiz-feedback.ok  { background: rgba(62,207,142,0.1); color: var(--green); border: 1px solid rgba(62,207,142,0.3); }
  .quiz-feedback.ng  { background: rgba(255,92,92,0.1);  color: var(--exit);  border: 1px solid rgba(255,92,92,0.3); }

  /* 정답 강조 박스 (오답 시) */
  .answer-reveal {
    display: none; margin-top: 12px;
    padding: 16px 18px; border-radius: 14px;
    background: rgba(37,99,235,0.06); border: 1.5px solid rgba(37,99,235,0.25);
  }
  .answer-reveal.show { display: block; }
  .answer-reveal-label { font-size: 0.75rem; color: var(--accent); font-weight: 700; letter-spacing: 1px; margin-bottom: 6px; }
  .answer-reveal-text  { font-size: 1rem; color: var(--accent); font-weight: 700; }

  /* OX 버튼 */
  .ox-btns { display: flex; gap: 16px; margin-top: 20px; width: 100%; max-width: 640px; }
  .ox-btn {
    flex: 1; padding: 22px; border: 2px solid var(--border);
    border-radius: 20px; background: var(--card);
    font-size: 2.5rem; cursor: pointer; transition: all 0.2s;
    font-family: 'Black Han Sans', sans-serif;
  }
  .ox-btn:hover:not(:disabled) { transform: scale(1.05); }
  .ox-btn.o-btn:hover:not(:disabled) { border-color: var(--green); background: rgba(62,207,142,0.1); }
  .ox-btn.x-btn:hover:not(:disabled) { border-color: var(--exit);  background: rgba(255,92,92,0.1); }
  .ox-btn.correct { border-color: var(--green); background: rgba(62,207,142,0.15); }
  .ox-btn.wrong   { border-color: var(--exit);  background: rgba(255,92,92,0.12); }
  .ox-btn:disabled { cursor: default; opacity: 0.7; }

  /* OX 문제 점수 강조 */
  .ox-score-highlight {
    display: inline-block; font-family: 'Black Han Sans', sans-serif;
    font-size: 1.6rem; color: var(--accent);
    background: rgba(37,99,235,0.08); border-radius: 8px;
    padding: 2px 12px; margin: 8px 0;
  }

  .btn-quiz-next {
    display: none; width: 100%; max-width: 640px;
    padding: 16px; border: none; border-radius: 16px;
    background: linear-gradient(135deg, var(--accent), #a78bfa);
    color: #fff; font-family: 'Noto Sans KR', sans-serif;
    font-size: 1rem; font-weight: 700; cursor: pointer; transition: all 0.2s;
  }
  .btn-quiz-next.show { display: block; }
  .btn-quiz-next:hover { filter: brightness(1.1); }

  /* --- RESULT --- */
  .result-card {
    background: var(--card); border: 1.5px solid var(--border);
    border-radius: 28px; padding: 36px 28px;
    text-align: center; width: 100%; max-width: 540px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
  }
  .result-emoji { font-size: 3.5rem; margin-bottom: 12px; }
  .result-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.8rem; margin-bottom: 6px; }
  .result-sub { color: var(--muted); font-size: 0.9rem; margin-bottom: 24px; }
  .result-score-big {
    font-family: 'Black Han Sans', sans-serif;
    font-size: 4.5rem; line-height: 1;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    margin-bottom: 6px;
  }
  .result-score-label { color: var(--muted); font-size: 0.9rem; margin-bottom: 20px; }

  /* 오답 통계 요약 */
  .result-stats {
    display: flex; gap: 10px; justify-content: center; margin-bottom: 20px; flex-wrap: wrap;
  }
  .result-stat-pill {
    padding: 8px 16px; border-radius: 99px; font-size: 0.82rem; font-weight: 700;
  }
  .pill-wrong { background: rgba(255,92,92,0.12); color: var(--exit); border: 1px solid rgba(255,92,92,0.3); }
  .pill-correct { background: rgba(62,207,142,0.12); color: var(--green); border: 1px solid rgba(62,207,142,0.3); }

  /* 틀린 문제 목록 */
  .wrong-list-wrap {
    display: none; text-align: left; margin-top: 16px;
    max-height: 260px; overflow-y: auto;
    border: 1px solid var(--border); border-radius: 16px;
    background: var(--bg);
  }
  .wrong-list-wrap.show { display: block; }
  .wrong-item {
    padding: 14px 16px; border-bottom: 1px solid var(--border);
    display: flex; align-items: flex-start; gap: 12px;
  }
  .wrong-item:last-child { border-bottom: none; }
  .wrong-num {
    font-size: 0.7rem; font-weight: 700; color: var(--exit);
    background: rgba(255,92,92,0.12); border-radius: 6px;
    padding: 2px 7px; white-space: nowrap; margin-top: 2px; flex-shrink: 0;
  }
  .wrong-content { font-size: 0.85rem; line-height: 1.6; flex: 1; }
  .wrong-score-row { display: flex; gap: 8px; margin-top: 5px; align-items: center; }
  .wrong-my   { font-size: 0.78rem; color: var(--exit); background: rgba(255,92,92,0.1); padding: 2px 8px; border-radius: 6px; }
  .wrong-ans  { font-size: 0.78rem; color: var(--gold); background: rgba(245,197,66,0.1); padding: 2px 8px; border-radius: 6px; font-weight: 700; }
  .wrong-tries { font-size: 0.72rem; color: var(--muted); margin-left: auto; }

  /* 누적 오답 횟수 배지 */
  .wrong-count-badge {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 20px; height: 20px; border-radius: 99px;
    background: var(--exit); color: #fff;
    font-size: 0.7rem; font-weight: 900; padding: 0 5px; margin-left: 6px;
    vertical-align: middle;
    box-shadow: 0 1px 4px rgba(220,38,38,0.3);
  }

  .result-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-top: 20px; }
  .btn-retry { padding: 12px 22px; border-radius: 14px; border: 1.5px solid var(--accent); background: transparent; color: var(--accent); font-family: 'Noto Sans KR', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
  .btn-retry:hover { background: rgba(79,142,247,0.1); }
  .btn-retry-wrong { padding: 12px 22px; border-radius: 14px; border: 1.5px solid var(--exit); background: rgba(255,92,92,0.08); color: var(--exit); font-family: 'Noto Sans KR', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
  .btn-retry-wrong:hover { background: rgba(255,92,92,0.15); }
  .btn-toggle-wrong { padding: 12px 22px; border-radius: 14px; border: 1.5px solid var(--border); background: transparent; color: var(--muted); font-family: 'Noto Sans KR', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
  .btn-toggle-wrong:hover { border-color: var(--gold); color: var(--gold); }
  .btn-home2 { padding: 12px 22px; border-radius: 14px; border: none; background: var(--accent); color: #fff; font-family: 'Noto Sans KR', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
  .btn-home2:hover { filter: brightness(1.1); }

  /* --- 자주 틀리는 항목 --- */
  .weak-screen-inner { width: 100%; max-width: 680px; }
  .weak-top { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
  .weak-title-text { font-family: 'Black Han Sans', sans-serif; font-size: 1.3rem; }
  .weak-empty {
    text-align: center; padding: 60px 24px;
    color: var(--muted); font-size: 0.95rem; line-height: 2;
  }
  .weak-empty-icon { font-size: 3rem; margin-bottom: 12px; }
  .weak-sub { font-size: 0.82rem; color: var(--muted); margin-bottom: 20px; }
  .weak-list { display: flex; flex-direction: column; gap: 10px; max-height: 65vh; overflow-y: auto; padding-right: 4px; }
  .weak-item {
    background: var(--card); border: 1.5px solid rgba(220,38,38,0.2);
    border-radius: 14px; padding: 14px 16px;
    display: flex; align-items: flex-start; gap: 12px;
    transition: border-color 0.2s;
    box-shadow: 0 1px 6px rgba(220,38,38,0.06);
  }
  .weak-item:hover { border-color: var(--exit); }
  .weak-rank-col { display: flex; flex-direction: column; align-items: center; gap: 4px; flex-shrink: 0; }
  .weak-rank {
    font-family: 'Black Han Sans', sans-serif; font-size: 1rem;
    color: var(--exit); min-width: 28px; text-align: center;
  }
  .weak-fire { font-size: 0.9rem; }
  .weak-body { flex: 1; }
  .weak-content-text { font-size: 0.9rem; line-height: 1.6; margin-bottom: 8px; }
  .weak-meta { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .weak-score-tag {
    font-size: 0.78rem; font-weight: 700; padding: 3px 10px; border-radius: 8px;
  }
  .weak-count-tag {
    font-size: 0.78rem; font-weight: 700; padding: 3px 10px; border-radius: 8px;
    background: rgba(255,92,92,0.12); color: var(--exit);
  }
  .weak-bar-wrap { flex: 1; min-width: 80px; background: var(--border); border-radius: 99px; height: 6px; overflow: hidden; }
  .weak-bar { height: 100%; border-radius: 99px; background: linear-gradient(90deg, var(--exit), var(--warning)); transition: width 0.6s; }
  .weak-action-row { display: flex; gap: 10px; margin-top: 16px; flex-wrap: wrap; }
  .btn-weak-quiz { padding: 12px 20px; border-radius: 14px; border: none; background: var(--exit); color: #fff; font-family: 'Noto Sans KR', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
  .btn-weak-quiz:hover { filter: brightness(1.1); }
  .btn-weak-ox { padding: 12px 20px; border-radius: 14px; border: 1.5px solid var(--exit); background: transparent; color: var(--exit); font-family: 'Noto Sans KR', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
  .btn-weak-ox:hover { background: rgba(255,92,92,0.08); }

  /* --- CATEGORY BROWSE --- */
  .cat-screen-inner { width: 100%; max-width: 680px; }
  .cat-top { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; }
  .cat-title-text { font-family: 'Black Han Sans', sans-serif; font-size: 1.3rem; }

  .cat-tabs {
    display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px;
  }
  .cat-tab {
    padding: 7px 16px; border-radius: 99px; border: 1.5px solid var(--border);
    background: var(--card); color: var(--muted);
    font-family: 'Noto Sans KR', sans-serif; font-size: 0.82rem; font-weight: 700;
    cursor: pointer; transition: all 0.2s; white-space: nowrap;
  }
  .cat-tab:hover { border-color: var(--accent); color: var(--text); }
  .cat-tab.active { color: #fff; border-color: transparent; }
  .cat-tab[data-cat="전체"].active   { background: #4a5568; }
  .cat-tab[data-cat="음주"].active   { background: #c05621; }
  .cat-tab[data-cat="폭력·성"].active { background: #9b2335; }
  .cat-tab[data-cat="무단이탈"].active { background: #2b6cb0; }
  .cat-tab[data-cat="흡연"].active   { background: #276749; }
  .cat-tab[data-cat="보고·허위"].active { background: #6b46c1; }
  .cat-tab[data-cat="품위·복장"].active { background: #744210; }
  .cat-tab[data-cat="시설·물품"].active { background: #2c7a7b; }
  .cat-tab[data-cat="수업·학습"].active { background: #285e61; }
  .cat-tab[data-cat="생활질서"].active { background: #4a5568; }
  .cat-tab[data-cat="퇴교"].active   { background: #9b2335; }

  .cat-list { display: flex; flex-direction: column; gap: 8px; max-height: 62vh; overflow-y: auto; padding-right: 4px; }
  .cat-item {
    background: var(--card); border: 1.5px solid var(--border);
    border-radius: 14px; padding: 14px 16px;
    display: flex; align-items: flex-start; gap: 12px;
    transition: border-color 0.2s;
    box-shadow: 0 1px 4px rgba(0,0,0,0.04);
  }
  .cat-item:hover { border-color: var(--accent); }
  .cat-score-badge {
    flex-shrink: 0; font-family: 'Black Han Sans', sans-serif;
    font-size: 0.85rem; padding: 4px 10px; border-radius: 8px;
    min-width: 52px; text-align: center; margin-top: 1px;
  }
  .badge-exit   { background: rgba(255,92,92,0.15);  color: var(--exit); }
  .badge-high   { background: rgba(255,159,67,0.15); color: var(--warning); }
  .badge-mid    { background: rgba(245,197,66,0.15); color: var(--gold); }
  .badge-low    { background: rgba(62,207,142,0.15); color: var(--green); }
  .badge-minor  { background: rgba(79,142,247,0.15); color: var(--accent); }
  .cat-item-content { font-size: 0.9rem; line-height: 1.6; color: var(--text); }
  .cat-keyword {
    display: inline-block; font-size: 0.7rem; color: var(--muted);
    background: var(--surface); border-radius: 4px; padding: 1px 6px; margin-top: 4px;
  }
  .cat-count { font-size: 0.78rem; color: var(--muted); margin-left: auto; white-space: nowrap; padding-top: 2px; }

  /* --- 문제 수 선택 모달 --- */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);
    z-index: 100; align-items: center; justify-content: center;
  }
  .modal-overlay.show { display: flex; }
  .modal-box {
    background: var(--card); border: 1.5px solid var(--border);
    border-radius: 24px; padding: 32px 28px;
    width: 100%; max-width: 400px; margin: 24px;
    animation: slideIn 0.25s ease both;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
  }
  .modal-title { font-family: 'Black Han Sans', sans-serif; font-size: 1.3rem; margin-bottom: 6px; }
  .modal-sub   { font-size: 0.85rem; color: var(--muted); margin-bottom: 24px; }
  .count-options { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 24px; }
  .count-opt {
    padding: 16px 8px; border-radius: 14px;
    border: 2px solid var(--border); background: var(--bg);
    font-family: 'Black Han Sans', sans-serif; font-size: 1.4rem;
    color: var(--text); cursor: pointer; text-align: center;
    transition: all 0.18s; position: relative;
  }
  .count-opt:hover { border-color: var(--accent); background: rgba(79,142,247,0.08); }
  .count-opt.selected { border-color: var(--accent); background: rgba(79,142,247,0.12); color: var(--accent); }
  .count-opt-label { display: block; font-size: 0.72rem; font-family: 'Noto Sans KR', sans-serif; color: var(--muted); margin-top: 4px; font-weight: 400; }
  .count-custom-row { display: flex; gap: 10px; align-items: center; margin-bottom: 24px; }
  .count-custom-input {
    flex: 1; padding: 12px 16px; border-radius: 12px;
    border: 2px solid var(--border); background: var(--bg);
    color: var(--text); font-family: 'Noto Sans KR', sans-serif; font-size: 1rem;
    transition: border-color 0.2s;
  }
  .count-custom-input:focus { outline: none; border-color: var(--accent); }
  .count-custom-label { font-size: 0.85rem; color: var(--muted); white-space: nowrap; }
  .modal-btns { display: flex; gap: 10px; }
  .modal-cancel { flex: 1; padding: 14px; border-radius: 14px; border: 1.5px solid var(--border); background: transparent; color: var(--muted); font-family: 'Noto Sans KR', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.2s; }
  .modal-cancel:hover { border-color: var(--text); color: var(--text); }
  .modal-start  { flex: 2; padding: 14px; border-radius: 14px; border: none; background: var(--accent); color: #fff; font-family: 'Noto Sans KR', sans-serif; font-weight: 700; font-size: 1rem; cursor: pointer; transition: all 0.2s; }
  .modal-start:hover { filter: brightness(1.1); }
  .modal-start.ox-start { background: var(--green); }

  /* Shuffle animation */
  @keyframes slideIn { from { opacity:0; transform: translateY(20px); } to { opacity:1; transform: translateY(0); } }
  .anim { animation: slideIn 0.35s ease both; }
</style>
</head>
<body>

<!-- HOME -->
<div class="screen active" id="home">
  <div class="home-title">상벌점 기준 학습</div>
  <div class="home-sub">플래시카드와 모의시험으로 완벽하게 암기하자 💪</div>
  <div class="mode-grid">
    <div class="mode-card flash" onclick="startFlash()">
      <div class="mode-icon">🃏</div>
      <div class="mode-label">플래시카드</div>
      <div class="mode-desc">내용 → 점수 순서로<br>하나씩 넘겨가며 암기</div>
    </div>
    <div class="mode-card quiz" onclick="openCountModal('quiz')">
      <div class="mode-icon">📝</div>
      <div class="mode-label">객관식</div>
      <div class="mode-desc">이 행위 몇 점?<br>4지선다 · 문제 수 선택</div>
    </div>
    <div class="mode-card ox" onclick="openCountModal('ox')">
      <div class="mode-icon">⭕</div>
      <div class="mode-label">O/X 퀴즈</div>
      <div class="mode-desc">점수 맞으면 O 틀리면 X<br>문제 수 선택</div>
    </div>
    <div class="mode-card" style="border-color:var(--border);grid-column:1/-1;" onclick="startCat()">
      <div class="mode-icon">📂</div>
      <div class="mode-label">유형별 보기</div>
      <div class="mode-desc">음주·폭력·무단이탈 등 비슷한 항목끼리 묶어서 한눈에 확인</div>
    </div>
    <div class="mode-card" style="border-color:rgba(255,92,92,0.4);grid-column:1/-1;position:relative;" onclick="startWeak()">
      <div style="position:absolute;top:12px;right:14px;" id="weakBadgeHome"></div>
      <div class="mode-icon">🔥</div>
      <div class="mode-label" style="color:var(--exit);">자주 틀리는 항목</div>
      <div class="mode-desc">3회 이상 틀린 항목만 모아 집중 복습</div>
    </div>
  </div>
  <div class="stats-row">
    <div class="stat-pill">총 <span id="total-count">0</span>개 항목</div>
    <div class="stat-pill">퇴교 <span>9</span>개 · 감점 <span>50</span>개</div>
  </div>
</div>

<!-- 자주 틀리는 항목 -->
<div class="screen" id="weakScreen">
  <div class="weak-screen-inner">
    <div class="weak-top">
      <button class="btn btn-home" onclick="goHome()" style="flex:0 0 auto;">← 홈</button>
      <div class="weak-title-text">🔥 자주 틀리는 항목</div>
      <div style="margin-left:auto;font-size:0.8rem;color:var(--muted);" id="weakCountDisp"></div>
    </div>
    <div class="weak-sub" id="weakSubMsg">3회 이상 틀린 항목을 집중 복습하세요!</div>
    <div class="weak-action-row" id="weakActionRow" style="margin-bottom:16px;display:none;">
      <button class="btn-weak-quiz" onclick="startWeakQuiz()">📝 객관식으로 풀기</button>
      <button class="btn-weak-ox"   onclick="startWeakOX()">⭕ O/X로 풀기</button>
    </div>
    <div id="weakContent"></div>
  </div>
</div>

<!-- FLASHCARD -->
<div class="screen" id="flashScreen">
  <div class="fc-header">
    <button class="btn btn-home" onclick="goHome()">← 홈</button>
    <div class="fc-progress-wrap">
      <div class="fc-progress-bar"><div class="fc-progress-fill" id="fcFill" style="width:0%"></div></div>
      <div class="fc-counter" id="fcCounter">1 / 59</div>
    </div>
    <button class="btn btn-home" onclick="shuffleCards()" style="font-size:1.2rem;padding:14px 16px;">🔀</button>
  </div>
  <div class="flashcard-wrap">
    <div class="flashcard" id="flashcard" onclick="flipCard()">
      <div class="fc-face fc-front">
        <div class="fc-hint">📋 내용 — 탭하여 점수 확인</div>
        <div class="fc-content" id="fcFront"></div>
      </div>
      <div class="fc-face fc-back">
        <div class="fc-hint">감점</div>
        <div class="fc-tag" id="fcTag"></div>
        <div class="fc-score" id="fcScore"></div>
        <div class="fc-score-label" id="fcScoreLabel"></div>
      </div>
    </div>
  </div>
  <div class="fc-actions">
    <button class="btn btn-prev" onclick="prevCard()">← 이전</button>
    <button class="btn btn-next" onclick="nextCard()">다음 →</button>
  </div>
</div>

<!-- CATEGORY BROWSE -->
<div class="screen" id="catScreen">
  <div class="cat-screen-inner">
    <div class="cat-top">
      <button class="btn btn-home" onclick="goHome()" style="flex:0 0 auto;">← 홈</button>
      <div class="cat-title-text">📂 유형별 보기</div>
      <div class="cat-count" id="catCountDisp" style="margin-left:auto;"></div>
    </div>
    <div class="cat-tabs" id="catTabs"></div>
    <div class="cat-list" id="catList"></div>
  </div>
</div>

<!-- QUIZ -->
<div class="screen" id="quizScreen">
  <div class="quiz-header">
    <div class="quiz-qnum" id="quizQNum">문제 1 / 20</div>
    <div class="quiz-score-disp">점수: <span id="quizScoreDisp">0</span></div>
  </div>
  <div class="quiz-progress-bar"><div class="quiz-progress-fill" id="quizFill" style="width:5%"></div></div>
  <div class="quiz-card anim" id="quizCard">
    <div class="quiz-q" id="quizQ"></div>
    <div class="quiz-options" id="quizOpts"></div>
    <div class="quiz-feedback" id="quizFb"></div>
    <div class="answer-reveal" id="quizReveal">
      <div class="answer-reveal-label">✅ 정답은</div>
      <div class="answer-reveal-text" id="quizRevealText"></div>
    </div>
  </div>
  <button class="btn-quiz-next" id="quizNextBtn" onclick="nextQuestion()">다음 문제 →</button>
</div>

<!-- OX QUIZ -->
<div class="screen" id="oxScreen">
  <div class="quiz-header">
    <div class="quiz-qnum" id="oxQNum">문제 1 / 20</div>
    <div style="display:flex;gap:12px;align-items:center;">
      <div class="quiz-score-disp">정답: <span id="oxScoreDisp" style="color:var(--green)">0</span></div>
      <button class="btn btn-home" onclick="goHome()" style="padding:8px 14px;font-size:0.85rem;">← 홈</button>
    </div>
  </div>
  <div class="quiz-progress-bar" style="margin-bottom:20px;"><div class="quiz-progress-fill" id="oxFill" style="width:5%"></div></div>
  <div class="quiz-card anim" id="oxCard">
    <div style="font-size:0.75rem;color:var(--muted);letter-spacing:1px;margin-bottom:10px;">💡 표시된 점수가 맞으면 O, 틀리면 X</div>
    <div class="quiz-q" id="oxQ" style="margin-bottom:16px;"></div>
    <div style="text-align:center;"><span class="ox-score-highlight" id="oxScoreShown"></span></div>
    <div class="quiz-feedback" id="oxFb"></div>
    <div class="answer-reveal" id="oxReveal">
      <div class="answer-reveal-label">✅ 정답은</div>
      <div class="answer-reveal-text" id="oxRevealText"></div>
    </div>
  </div>
  <div class="ox-btns">
    <button class="ox-btn o-btn" id="oxBtnO" onclick="answerOX(true)">⭕</button>
    <button class="ox-btn x-btn" id="oxBtnX" onclick="answerOX(false)">❌</button>
  </div>
  <button class="btn-quiz-next" id="oxNextBtn" onclick="nextOX()" style="margin-top:16px;max-width:640px;">다음 문제 →</button>
</div>

<!-- RESULT -->
<div class="screen" id="resultScreen">
  <div class="result-card anim">
    <div class="result-emoji" id="resultEmoji">🎉</div>
    <div class="result-title" id="resultTitle">결과</div>
    <div class="result-sub" id="resultSub"></div>
    <div class="result-score-big" id="resultBig"></div>
    <div class="result-score-label" id="resultLabel">점 / 100점</div>
    <div class="result-stats" id="resultStats"></div>
    <div class="wrong-list-wrap" id="wrongListWrap"></div>
    <div class="result-btns">
      <button class="btn-toggle-wrong" id="btnToggleWrong" onclick="toggleWrongList()" style="display:none;">📋 오답 보기</button>
      <button class="btn-retry-wrong" id="btnRetryWrong" onclick="retryWrong()" style="display:none;">🔁 틀린 문제만</button>
      <button class="btn-retry" id="btnRetryAll" onclick="retryAll()">🔄 다시 풀기</button>
      <button class="btn-home2" onclick="goHome()">홈으로</button>
    </div>
  </div>
</div>

<!-- 문제 수 선택 모달 -->
<div class="modal-overlay" id="countModal">
  <div class="modal-box">
    <div class="modal-title" id="modalTitle">문제 수 선택</div>
    <div class="modal-sub" id="modalSub">몇 문제를 풀까요? (최대 <span id="modalMax">51</span>문제)</div>
    <div class="count-options">
      <button class="count-opt selected" data-val="10" onclick="selectCount(this)">
        10<span class="count-opt-label">빠르게</span>
      </button>
      <button class="count-opt" data-val="20" onclick="selectCount(this)">
        20<span class="count-opt-label">기본</span>
      </button>
      <button class="count-opt" data-val="30" onclick="selectCount(this)">
        30<span class="count-opt-label">꼼꼼하게</span>
      </button>
      <button class="count-opt" data-val="all" onclick="selectCount(this)">
        전체<span class="count-opt-label" id="modalAllLabel">51문제</span>
      </button>
    </div>
    <div class="count-custom-row">
      <span class="count-custom-label">직접 입력</span>
      <input class="count-custom-input" id="countCustomInput" type="number" min="1" placeholder="예: 15" oninput="onCustomInput(this)">
      <span class="count-custom-label">문제</span>
    </div>
    <div class="modal-btns">
      <button class="modal-cancel" onclick="closeCountModal()">취소</button>
      <button class="modal-start" id="modalStartBtn" onclick="confirmCountModal()">시작 →</button>
    </div>
  </div>
</div>

