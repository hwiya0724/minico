function getTopics(item) {
  return TOPIC_MAP.filter(t => t.key !== '퇴교' && t.match(item)).map(t => t.key);
}

function getBadgeClass(cat) {
  return { exit:'badge-exit', high:'badge-high', mid:'badge-mid', low:'badge-low', minor:'badge-minor' }[cat] || 'badge-minor';
}

let currentCatKey = '전체';

function startCat() {
  currentCatKey = '전체';
  showScreen('catScreen');
  buildCatTabs();
  renderCatList();
}

function buildCatTabs() {
  const tabs = document.getElementById('catTabs');
  tabs.innerHTML = '';
  const allTabs = [{ key:'전체', label:'📋 전체' }, ...TOPIC_MAP];
  allTabs.forEach(t => {
    const btn = document.createElement('button');
    btn.className = 'cat-tab' + (t.key === currentCatKey ? ' active' : '');
    btn.dataset.cat = t.key;
    btn.textContent = t.label || t.key;
    // count
    const cnt = t.key === '전체' ? DATA.length : DATA.filter(t.match || (() => false)).length;
    btn.textContent = (t.label || t.key) + ` (${cnt})`;
    btn.onclick = () => { currentCatKey = t.key; buildCatTabs(); renderCatList(); };
    tabs.appendChild(btn);
  });
}

function renderCatList() {
  const list = document.getElementById('catList');
  list.innerHTML = '';

  let items;
  if (currentCatKey === '전체') {
    items = DATA;
  } else {
    const topic = TOPIC_MAP.find(t => t.key === currentCatKey);
    items = topic ? DATA.filter(topic.match) : DATA;
  }

  document.getElementById('catCountDisp').textContent = `${items.length}개 항목`;

  items.forEach(item => {
    const topics = getTopics(item);
    const div = document.createElement('div');
    div.className = 'cat-item anim';
    div.innerHTML = `
      <span class="cat-score-badge ${getBadgeClass(item.cat)}">${item.score}</span>
      <div class="cat-item-content">
        ${item.content.replace(/\n/g, '<br>')}
        <div style="margin-top:6px;display:flex;gap:4px;flex-wrap:wrap;">
          ${topics.map(t => `<span class="cat-keyword">${TOPIC_MAP.find(x=>x.key===t)?.label||t}</span>`).join('')}
        </div>
      </div>`;
    list.appendChild(div);
  });

  if (!items.length) {
    list.innerHTML = '<div style="color:var(--muted);padding:24px;text-align:center;">해당 항목이 없어요</div>';
  }
}

