function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function goHome() { showScreen('home'); }

function shuffleArr(a) {
  for (let i = a.length-1; i>0; i--) {
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

// --- 문제 수 선택 모달 ---
let modalMode = 'quiz';   // 'quiz' | 'ox'
let selectedCount = 10;
let modalPool = null;     // null이면 전체 DATA 사용, 배열이면 해당 풀 사용

function openCountModal(mode, pool = null) {
  modalMode = mode;
  modalPool = pool;
  const maxN = pool ? pool.length : DATA.length;

  document.getElementById('modalTitle').textContent = mode === 'quiz' ? '📝 객관식 — 문제 수 선택' : '⭕ O/X — 문제 수 선택';
  document.getElementById('modalSub').innerHTML = `몇 문제를 풀까요? (최대 <span id="modalMax">${maxN}</span>문제)`;
  document.getElementById('modalAllLabel').textContent = `${maxN}문제`;
  document.getElementById('modalStartBtn').className = mode === 'quiz' ? 'modal-start' : 'modal-start ox-start';
  document.getElementById('countCustomInput').value = '';

  // 기본 선택 10으로 리셋
  selectedCount = Math.min(10, maxN);
  document.querySelectorAll('.count-opt').forEach(b => b.classList.remove('selected'));
  const def = document.querySelector('.count-opt[data-val="10"]');
  if (def) def.classList.add('selected');

  // 최대치 초과 옵션 비활성화
  document.querySelectorAll('.count-opt[data-val]').forEach(b => {
    const v = b.dataset.val;
    if (v !== 'all' && parseInt(v) > maxN) {
      b.style.opacity = '0.35'; b.style.pointerEvents = 'none';
    } else {
      b.style.opacity = ''; b.style.pointerEvents = '';
    }
  });

  document.getElementById('countModal').classList.add('show');
}

function closeCountModal() {
  document.getElementById('countModal').classList.remove('show');
}

function selectCount(btn) {
  document.querySelectorAll('.count-opt').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  document.getElementById('countCustomInput').value = '';
  const maxN = modalPool ? modalPool.length : DATA.length;
  selectedCount = btn.dataset.val === 'all' ? maxN : Math.min(parseInt(btn.dataset.val), maxN);
}

function onCustomInput(input) {
  document.querySelectorAll('.count-opt').forEach(b => b.classList.remove('selected'));
  const maxN = modalPool ? modalPool.length : DATA.length;
  const v = Math.max(1, Math.min(parseInt(input.value) || 1, maxN));
  selectedCount = v;
}

function confirmCountModal() {
  // 직접입력값 우선
  const customVal = document.getElementById('countCustomInput').value;
  if (customVal !== '') {
    const maxN = modalPool ? modalPool.length : DATA.length;
    selectedCount = Math.max(1, Math.min(parseInt(customVal) || 1, maxN));
  }
  closeCountModal();
  if (modalMode === 'quiz') startQuiz(selectedCount, modalPool);
  else startOX(selectedCount, modalPool);
}

