// --- QUIZ ---
const QUIZ_COUNT = 20;
let quizQuestions = [], quizIdx = 0, quizScore = 0, answered = false;
let quizWrongItems = []; // {q, myAnswer} for this session
let currentMode = 'quiz'; // 'quiz' | 'ox'
let isRetryMode = false;

// 누적 오답 횟수 저장 (content → count)
const wrongCounts = {};
const WEAK_THRESHOLD = 3; // 3회 이상 틀리면 자주 틀리는 항목

function getWeakItems() {
  return DATA
    .filter(d => (wrongCounts[d.content] || 0) >= WEAK_THRESHOLD)
    .sort((a, b) => (wrongCounts[b.content] || 0) - (wrongCounts[a.content] || 0));
}

function updateWeakBadge() {
  const count = getWeakItems().length;
  const badge = document.getElementById('weakBadgeHome');
  if (badge) {
    badge.innerHTML = count > 0
      ? `<span style="background:var(--exit);color:#fff;font-size:0.72rem;font-weight:900;padding:3px 8px;border-radius:99px;">🔥 ${count}개</span>`
      : '';
  }
}

function startWeak() {
  showScreen('weakScreen');
  renderWeakScreen();
}

function renderWeakScreen() {
  const weak = getWeakItems();
  const maxCount = weak.length > 0 ? (wrongCounts[weak[0].content] || 1) : 1;

  document.getElementById('weakCountDisp').textContent = weak.length > 0 ? `총 ${weak.length}개` : '';
  document.getElementById('weakActionRow').style.display = weak.length > 0 ? 'flex' : 'none';

  const content = document.getElementById('weakContent');
  content.innerHTML = '';

  if (weak.length === 0) {
    content.innerHTML = `
      <div class="weak-empty">
        <div class="weak-empty-icon">🎉</div>
        <div>아직 3회 이상 틀린 항목이 없어요!</div>
        <div style="font-size:0.82rem;color:var(--muted);margin-top:8px;">객관식·O/X 퀴즈를 풀다 보면<br>자주 틀리는 항목이 여기에 모여요.</div>
      </div>`;
    document.getElementById('weakSubMsg').style.display = 'none';
    return;
  }

  document.getElementById('weakSubMsg').style.display = 'block';

  const list = document.createElement('div');
  list.className = 'weak-list';

  weak.forEach((item, i) => {
    const cnt = wrongCounts[item.content] || 0;
    const barPct = Math.round((cnt / maxCount) * 100);
    const fire = cnt >= 7 ? '🔥🔥🔥' : cnt >= 5 ? '🔥🔥' : '🔥';

    const div = document.createElement('div');
    div.className = 'weak-item anim';
    div.innerHTML = `
      <div class="weak-rank-col">
        <div class="weak-rank">${i + 1}위</div>
        <div class="weak-fire">${fire}</div>
      </div>
      <div class="weak-body">
        <div class="weak-content-text">${item.content.replace(/\n/g, '<br>')}</div>
        <div class="weak-meta">
          <span class="weak-score-tag ${getBadgeClass(item.cat)}">${item.score}</span>
          <span class="weak-count-tag">✗ ${cnt}번 틀림</span>
          <div class="weak-bar-wrap"><div class="weak-bar" style="width:${barPct}%"></div></div>
        </div>
      </div>`;
    list.appendChild(div);
  });

  content.appendChild(list);
}

function startWeakQuiz() {
  const weak = getWeakItems();
  if (!weak.length) return;
  openCountModal('quiz', weak);
}

function startWeakOX() {
  const weak = getWeakItems();
  if (!weak.length) return;
  openCountModal('ox', weak);
}

function makeQuestions(pool) {
  return pool.map(item => {
    const correct = item.score;
    const allScores = [...new Set(DATA.map(d => d.score))];
    const wrongs = shuffleArr(allScores.filter(s => s !== correct)).slice(0, 3);
    const opts = shuffleArr([correct, ...wrongs]);
    return {
      item,
      q: `다음 위반 행위는 몇 점 감점일까요?\n\n"${item.content}"`,
      opts, correct,
      explanation: `이 행위의 감점은 ${correct}입니다.`
    };
  });
}

function startQuiz(count = 20, pool = null) {
  currentMode = 'quiz';
  isRetryMode = false;
  const src = pool ? shuffleArr([...pool]) : shuffleArr([...DATA]);
  const slice = src.slice(0, Math.min(count, src.length));
  quizQuestions = makeQuestions(slice);
  quizIdx = 0; quizScore = 0; answered = false; quizWrongItems = [];
  showScreen('quizScreen');
  renderQuestion();
}

function retryAll() {
  openCountModal(currentMode);
}

function retryWrong() {
  isRetryMode = true;
  if (currentMode === 'quiz') {
    if (!quizWrongItems.length) return;
    const wrongPool = quizWrongItems.map(w => w.item);
    quizIdx = 0; quizScore = 0; answered = false; quizWrongItems = [];
    quizQuestions = makeQuestions(wrongPool);
    showScreen('quizScreen');
    renderQuestion();
  } else {
    if (!oxWrongItems.length) return;
    const wrongPool = oxWrongItems.map(w => w.item);
    oxIdx = 0; oxScore = 0; oxAnswered = false; oxWrongItems = [];
    oxQuestions = makeOXQuestions(wrongPool);
    showScreen('oxScreen');
    renderOX();
  }
}

function renderQuestion() {
  const total = quizQuestions.length;
  const q = quizQuestions[quizIdx];
  answered = false;

  document.getElementById('quizQNum').textContent = `문제 ${quizIdx+1} / ${total}`;
  document.getElementById('quizScoreDisp').textContent = quizScore;
  document.getElementById('quizFill').style.width = ((quizIdx+1)/total*100) + '%';
  document.getElementById('quizQ').textContent = q.q;

  // 오답 횟수 배지
  const cnt = wrongCounts[q.item.content] || 0;
  const badge = cnt > 0 ? `<span class="wrong-count-badge" title="누적 ${cnt}번 틀림">✗${cnt}</span>` : '';
  document.getElementById('quizQ').innerHTML = q.q.replace('\n\n', '<br><br>') + badge;

  const optsEl = document.getElementById('quizOpts');
  optsEl.innerHTML = '';
  q.opts.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quiz-opt';
    btn.textContent = opt;
    btn.onclick = () => selectAnswer(btn, opt);
    optsEl.appendChild(btn);
  });

  document.getElementById('quizFb').className = 'quiz-feedback';
  document.getElementById('quizFb').textContent = '';
  document.getElementById('quizReveal').className = 'answer-reveal';
  document.getElementById('quizRevealText').textContent = '';

  const nb = document.getElementById('quizNextBtn');
  nb.className = 'btn-quiz-next';
  nb.textContent = quizIdx === total-1 ? '결과 보기 🎯' : '다음 문제 →';

  document.getElementById('quizCard').classList.remove('anim');
  void document.getElementById('quizCard').offsetWidth;
  document.getElementById('quizCard').classList.add('anim');
}

function selectAnswer(btn, val) {
  if (answered) return;
  answered = true;

  const q = quizQuestions[quizIdx];
  document.querySelectorAll('.quiz-opt').forEach(b => {
    b.disabled = true;
    if (b.textContent === q.correct) b.classList.add('correct');
  });

  const fb = document.getElementById('quizFb');
  if (val === q.correct) {
    quizScore++;
    btn.classList.add('correct');
    fb.textContent = '✅ 정답! ' + q.explanation;
    fb.className = 'quiz-feedback show ok';
    document.getElementById('quizReveal').className = 'answer-reveal';
  } else {
    btn.classList.add('wrong');
    fb.textContent = '❌ 오답입니다!';
    fb.className = 'quiz-feedback show ng';
    document.getElementById('quizRevealText').textContent = `정답: ${q.correct}  —  ${q.explanation}`;
    document.getElementById('quizReveal').className = 'answer-reveal show';
    // 누적 오답 기록
    wrongCounts[q.item.content] = (wrongCounts[q.item.content] || 0) + 1;
    quizWrongItems.push({ item: q.item, myAnswer: val, correct: q.correct });
    updateWeakBadge();
  }
  document.getElementById('quizScoreDisp').textContent = quizScore;
  document.getElementById('quizNextBtn').classList.add('show');
}

function nextQuestion() {
  if (!answered) return;
  quizIdx++;
  if (quizIdx >= quizQuestions.length) { showResult(); return; }
  renderQuestion();
}

// --- OX QUIZ ---
const OX_COUNT = 20;
let oxQuestions = [], oxIdx = 0, oxScore = 0, oxAnswered = false;
let oxWrongItems = [];

function makeOXQuestions(pool) {
  return pool.map(item => {
    const isCorrect = Math.random() < 0.5;
    const allScores = [...new Set(DATA.map(d => d.score))];
    const wrongScores = allScores.filter(s => s !== item.score);
    const shownScore = isCorrect ? item.score : shuffleArr(wrongScores)[0];
    return { item, content: item.content, realScore: item.score, shownScore, isCorrect };
  });
}

function startOX(count = 20, pool = null) {
  currentMode = 'ox';
  isRetryMode = false;
  const src = pool ? shuffleArr([...pool]) : shuffleArr([...DATA]);
  const slice = src.slice(0, Math.min(count, src.length));
  oxQuestions = makeOXQuestions(slice);
  oxIdx = 0; oxScore = 0; oxAnswered = false; oxWrongItems = [];
  showScreen('oxScreen');
  renderOX();
}

function renderOX() {
  const total = oxQuestions.length;
  const q = oxQuestions[oxIdx];
  oxAnswered = false;

  document.getElementById('oxQNum').textContent = `문제 ${oxIdx+1} / ${total}`;
  document.getElementById('oxScoreDisp').textContent = oxScore;
  document.getElementById('oxFill').style.width = ((oxIdx+1)/total*100) + '%';

  const cnt = wrongCounts[q.content] || 0;
  const badge = cnt > 0 ? ` <span class="wrong-count-badge">✗${cnt}</span>` : '';
  document.getElementById('oxQ').innerHTML = `"${q.content}"` + badge;
  document.getElementById('oxScoreShown').textContent = q.shownScore + ' 감점';

  document.getElementById('oxFb').className = 'quiz-feedback';
  document.getElementById('oxFb').textContent = '';
  document.getElementById('oxReveal').className = 'answer-reveal';
  document.getElementById('oxRevealText').textContent = '';

  const btnO = document.getElementById('oxBtnO');
  const btnX = document.getElementById('oxBtnX');
  btnO.disabled = false; btnX.disabled = false;
  btnO.className = 'ox-btn o-btn';
  btnX.className = 'ox-btn x-btn';

  document.getElementById('oxNextBtn').className = 'btn-quiz-next';
  document.getElementById('oxNextBtn').textContent = oxIdx === total-1 ? '결과 보기 🎯' : '다음 문제 →';

  document.getElementById('oxCard').classList.remove('anim');
  void document.getElementById('oxCard').offsetWidth;
  document.getElementById('oxCard').classList.add('anim');
}

function answerOX(userSaysO) {
  if (oxAnswered) return;
  oxAnswered = true;

  const q = oxQuestions[oxIdx];
  const isRight = (userSaysO === q.isCorrect);

  document.getElementById('oxBtnO').disabled = true;
  document.getElementById('oxBtnX').disabled = true;

  const fb = document.getElementById('oxFb');
  if (isRight) {
    oxScore++;
    document.getElementById(userSaysO ? 'oxBtnO' : 'oxBtnX').classList.add('correct');
    fb.textContent = `✅ 정답! 실제 감점은 ${q.realScore}입니다.`;
    fb.className = 'quiz-feedback show ok';
    document.getElementById('oxReveal').className = 'answer-reveal';
  } else {
    document.getElementById(userSaysO ? 'oxBtnO' : 'oxBtnX').classList.add('wrong');
    fb.textContent = `❌ 오답!`;
    fb.className = 'quiz-feedback show ng';
    document.getElementById('oxRevealText').textContent =
      `실제 감점은 ${q.realScore} — 표시된 ${q.shownScore}은 ${q.isCorrect ? '맞았습니다' : '틀렸습니다'}.`;
    document.getElementById('oxReveal').className = 'answer-reveal show';
    wrongCounts[q.content] = (wrongCounts[q.content] || 0) + 1;
    oxWrongItems.push({ item: q.item, myAnswer: userSaysO ? 'O' : 'X', correct: q.realScore });
    updateWeakBadge();
  }
  document.getElementById('oxScoreDisp').textContent = oxScore;
  document.getElementById('oxNextBtn').classList.add('show');
}

function nextOX() {
  if (!oxAnswered) return;
  oxIdx++;
  if (oxIdx >= oxQuestions.length) { showOXResult(); return; }
  renderOX();
}

function showOXResult() {
  const total = oxQuestions.length;
  const pct = Math.round(oxScore / total * 100);
  const wrongCount = oxWrongItems.length;
  buildResult(pct, oxScore, total, wrongCount, wrongCount > 0, 'O/X까지 완벽 마스터!');
}

// --- RESULT ---
let wrongListVisible = false;
let currentWrongItems = [];

function toggleWrongList() {
  wrongListVisible = !wrongListVisible;
  const wrap = document.getElementById('wrongListWrap');
  const btn = document.getElementById('btnToggleWrong');
  wrap.className = wrongListVisible ? 'wrong-list-wrap show' : 'wrong-list-wrap';
  btn.textContent = wrongListVisible ? '📋 오답 닫기' : '📋 오답 보기';
}

function buildResult(pct, correct, total, wrongCount, hasWrong, perfectMsg) {
  showScreen('resultScreen');
  document.getElementById('resultBig').textContent = pct;
  document.getElementById('resultLabel').textContent = `점 / 100점  (${correct}/${total} 정답)`;

  let emoji, title, sub;
  if (pct >= 90)      { emoji='🏆'; title='완벽해요!';  sub = perfectMsg; }
  else if (pct >= 70) { emoji='👍'; title='잘했어요!';  sub='조금만 더 복습하면 완벽해요.'; }
  else if (pct >= 50) { emoji='📚'; title='더 공부해요'; sub='플래시카드로 한번 더 복습해봐요!'; }
  else                { emoji='💪'; title='다시 도전!';  sub='차근차근 시작해봐요.'; }

  document.getElementById('resultEmoji').textContent = emoji;
  document.getElementById('resultTitle').textContent = title;
  document.getElementById('resultSub').textContent = sub;

  // 통계 알약
  const statsEl = document.getElementById('resultStats');
  statsEl.innerHTML = `
    <span class="result-stat-pill pill-correct">✅ 정답 ${correct}개</span>
    <span class="result-stat-pill pill-wrong">❌ 오답 ${wrongCount}개</span>
  `;

  // 오답 목록 렌더
  const wrongSource = currentMode === 'quiz' ? quizWrongItems : oxWrongItems;
  currentWrongItems = wrongSource;
  wrongListVisible = false;
  const wrap = document.getElementById('wrongListWrap');
  wrap.className = 'wrong-list-wrap';
  wrap.innerHTML = '';

  if (hasWrong) {
    wrongSource.forEach((w, i) => {
      const totalWrong = wrongCounts[w.item.content] || 1;
      const div = document.createElement('div');
      div.className = 'wrong-item';
      div.innerHTML = `
        <span class="wrong-num">${i+1}번</span>
        <div class="wrong-content">
          <div>${w.item.content}</div>
          <div class="wrong-score-row">
            <span class="wrong-my">내 답: ${w.myAnswer}</span>
            <span class="wrong-ans">정답: ${w.correct}</span>
            <span class="wrong-tries">누적 ${totalWrong}번 틀림</span>
          </div>
        </div>`;
      wrap.appendChild(div);
    });

    document.getElementById('btnToggleWrong').style.display = 'block';
    document.getElementById('btnToggleWrong').textContent = '📋 오답 보기';
    document.getElementById('btnRetryWrong').style.display = 'block';
  } else {
    document.getElementById('btnToggleWrong').style.display = 'none';
    document.getElementById('btnRetryWrong').style.display = 'none';
  }
  document.getElementById('btnRetryAll').textContent = '🔄 전체 다시 풀기';
}

function showResult() {
  const total = quizQuestions.length;
  const wrongCount = quizWrongItems.length;
  buildResult(
    Math.round(quizScore / total * 100),
    quizScore, total, wrongCount, wrongCount > 0,
    '상벌점 기준을 완전히 마스터했어요!'
  );
}
</script>
